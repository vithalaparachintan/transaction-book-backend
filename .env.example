# ⛔ BACKEND ENVIRONMENT - DO NOT COMMIT REAL SECRETS!
# Copy values from deployment guide

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Development: mongodb://localhost:27017/transactionBookDB
# Production: MongoDB Atlas - https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb://localhost:27017/transactionBookDB

# JWT Authentication
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=backend_secret_key_do_not_expose_change_in_production_32_chars_minimum
JWT_EXPIRY=7d

# Razorpay Payment Gateway
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_JsJIFvRNpRvJBD
RAZORPAY_KEY_SECRET=TkPYNLe5flGn3N3EbB9cBf9K

# CORS Configuration
# Development: *
# Production: https://your-frontend.vercel.app
CORS_ORIGIN=*

# Payment Limits (in paise)
DAILY_LIMIT=100000
MONTHLY_LIMIT=1000000

# Fee Configuration
PAYMENT_FEE_PERCENTAGE=2
PAYMENT_FEE_MINIMUM=1
GST_PERCENTAGE=18

# Database Retry
DB_CONNECT_RETRY_MS=5000
GST_PERCENTAGE=18

# Wallet Settings
DAILY_LIMIT=100000
MONTHLY_LIMIT=1000000

# Database Retry
DB_CONNECT_RETRY_MS=5000

# Logging
LOG_LEVEL=debug

